{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "BLXCode",
  "version": "0.1.14",
  "identifier": "com.bitslix.blxcode",
  "build": {
    "beforeDevCommand": "node scripts/tauri-before-build.cjs --dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "node scripts/tauri-before-build.cjs",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BLXCode",
        "width": 800,
        "height": 600,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "../content/hooks/claude_title.py",
      "../content/hooks/codex_title.py",
      "../content/hooks/claude_session_capture.py",
      "../content/hooks/codex_session_capture.py",
      "../content/hooks/gemini_title.py",
      "../content/hooks/gemini_session_capture.py",
      "../content/hooks/cursor_title.py",
      "../content/hooks/cursor_session_capture.py"
    ]
  }
}
