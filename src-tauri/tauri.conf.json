{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "blxcode",
  "version": "0.1.0",
  "identifier": "com.bitslix.blxcode.app",
  "build": {
    "beforeDevCommand": "env -u NO_COLOR PATH=\"$HOME/.cargo/bin:$PATH\" trunk serve",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "env -u NO_COLOR PATH=\"$HOME/.cargo/bin:$PATH\" trunk build",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "blxcode",
        "width": 800,
        "height": 600,
        "transparent": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
